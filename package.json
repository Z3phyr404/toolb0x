{
  "name": "finanz-app",
  "version": "1.0.0",
  "description": "Persönliche Finanz-App mit Liquid Glass UI",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "npx prisma migrate deploy && node server.js",
