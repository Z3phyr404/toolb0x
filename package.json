    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "validator": "^13.12.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "hpp": "^0.2.3"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
