// ============================================================
// DATENBANK-SCHEMA — mit Verschlüsselung
// ============================================================
// Sensible Felder (name, amount) werden als String gespeichert,
// weil der verschlüsselte Text ein Base64-String ist.
// In der DB sieht man nur Kauderwelsch.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("user")  // "user" | "admin"
  suspended    Boolean  @default(false)   // Gesperrte Nutzer können sich nicht einloggen
  encryptedKey String   // Encryption Key, verschlüsselt mit dem User-Passwort

  // Schlüsselpaar für geteilte Tresore (RSA-OAEP).
  // publicKey ist öffentlich (Klartext-PEM) — damit können andere Nutzer
  // Tresor-Schlüssel für diesen User verschlüsseln, ohne dass er online ist.
  // encryptedPrivateKey ist mit dem User-Encryption-Key verschlüsselt
  // (Zero-Knowledge bleibt gewahrt). Wird beim Login provisioniert.
  publicKey           String @default("")
  encryptedPrivateKey String @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories  Category[]
  expenses    Expense[]
  incomes     Income[]
  monthInits  MonthInit[]
  reminders   Reminder[]
  notes           Note[]
  storedPasswords StoredPassword[]
  servers         Server[]
  shares          Share[]
  ownedVaults      Vault[]       @relation("VaultOwner")
  vaultMemberships VaultMember[]

  @@map("users")
}

model Category {
  id    String @id @default(uuid())
  name  String   // VERSCHLÜSSELT
  color String   // VERSCHLÜSSELT

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("categories")
}

model Expense {
  id     String @id @default(uuid())
  name   String   // VERSCHLÜSSELT
  amount String   // VERSCHLÜSSELT (String weil Base64)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  tags       String   @default("")   // VERSCHLÜSSELT (JSON-Array als String, z.B. '["Wocheneinkauf","Online"]')

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       String  @default("2026-02")  // NICHT verschlüsselt (für DB-Queries)
  isRecurring Boolean @default(true)

  reminders Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@map("expenses")
}

model Income {
  id     String @id @default(uuid())
  name   String   // VERSCHLÜSSELT
  amount String   // VERSCHLÜSSELT

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       String  @default("2026-02")
  isRecurring Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@map("incomes")
}

// Trackt ob ein Monat bereits für einen User initialisiert wurde.
// Verhindert dass gelöschte Einträge nach einem Refresh wieder auftauchen.
model MonthInit {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  month  String  // Format: "YYYY-MM"
  type   String  // "expense" | "income"

  createdAt DateTime @default(now())

  @@unique([userId, month, type])
  @@index([userId, month])
  @@map("month_inits")
}

// ============================================================
// ERINNERUNGEN — Kündigungserinnerungen für Ausgaben
// ============================================================
// reminderDate und daysBefore sind NICHT verschlüsselt (für DB-Queries).
// note ist verschlüsselt (Zero-Knowledge).
// expenseId ist optional — Erinnerung überlebt gelöschte Ausgabe (SetNull).
// ============================================================
model Reminder {
  id           String   @id @default(uuid())
  note         String   @default("")   // VERSCHLÜSSELT (optionale Notiz)
  reminderDate DateTime                // NICHT verschlüsselt (für DB-Queries)
  daysBefore   Int      @default(3)    // Tage vorher erinnern (0–90)
  status       String   @default("pending") // "pending" | "done" | "dismissed"

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, reminderDate])
  @@map("reminders")
}

// ============================================================
// NOTIZEN — Hierarchische Seiten (Notion-ähnlich)
// ============================================================
// title und content sind VERSCHLÜSSELT (Zero-Knowledge).
// icon, sortOrder, isPinned, isArchived sind NICHT verschlüsselt
// (für Queries/Sortierung nötig).
// Self-Relation: Seiten können beliebig tief verschachtelt werden.
// onDelete: Cascade — Löschen einer Seite löscht alle Unterseiten.
// ============================================================
model Note {
  id         String   @id @default(uuid())
  title      String   // VERSCHLÜSSELT
  content    String   @db.Text // VERSCHLÜSSELT (HTML aus WYSIWYG-Editor)
  icon       String   @default("") // Emoji-Icon, NICHT verschlüsselt
  parentId   String?
  parent     Note?    @relation("NoteHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   Note[]   @relation("NoteHierarchy")
  sortOrder  Int      @default(0)
  isPinned   Boolean  @default(false)
  isArchived Boolean  @default(false)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, parentId])
  @@index([userId, isPinned])
  @@map("notes")
}

model StoredPassword {
  id       String @id @default(uuid())
  name     String // VERSCHLÜSSELT — Bezeichnung (z.B. "Netflix")
  username String @default("") // VERSCHLÜSSELT — Benutzername/E-Mail
  password String // VERSCHLÜSSELT — Das gespeicherte Passwort
  website  String @default("") // VERSCHLÜSSELT — URL (optional)
  notes    String @default("") // VERSCHLÜSSELT — Notizen (optional)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional: Eintrag liegt in einem geteilten Tresor.
  // Dann sind die Felder mit dem TRESOR-Schlüssel verschlüsselt (nicht mit
  // dem User-Key) und alle Tresor-Mitglieder können lesen/schreiben.
  // userId bleibt der Ersteller (für Anzeige "von wem").
  vaultId String?
  vault   Vault?  @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([vaultId])
  @@map("stored_passwords")
}

// ============================================================
// GETEILTE TRESORE — Gemeinsame Passwörter zwischen Nutzern
// ============================================================
// Jeder Tresor hat einen eigenen zufälligen AES-256-Schlüssel.
// Dieser wird pro Mitglied mit dessen RSA-Public-Key verschlüsselt
// (VaultMember.wrappedKey) — der Server kann ihn nie im Klartext
// aus der DB lesen (Zero-Knowledge at rest, wie beim User-Key).
// name ist mit dem Tresor-Schlüssel verschlüsselt.
// ============================================================
model Vault {
  id   String @id @default(uuid())
  name String // VERSCHLÜSSELT (mit dem Tresor-Schlüssel)

  ownerId String
  owner   User   @relation("VaultOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members   VaultMember[]
  passwords StoredPassword[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("vaults")
}

model VaultMember {
  id String @id @default(uuid())

  vaultId String
  vault   Vault  @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tresor-Schlüssel, RSA-OAEP-verschlüsselt mit dem Public Key des Mitglieds
  wrappedKey String @db.Text
  role       String @default("member") // "owner" | "member"

  createdAt DateTime @default(now())

  @@unique([vaultId, userId])
  @@index([userId])
  @@map("vault_members")
}

// ============================================================
// SERVER — Verwaltete Remote-Server (SSH-Zugang)
// ============================================================
// Sensible Felder sind VERSCHLÜSSELT (Zero-Knowledge).
// label, authType sind NICHT verschlüsselt (für Anzeige/Queries).
// ============================================================
model Server {
  id         String  @id @default(uuid())
  label      String  // NICHT verschlüsselt — Anzeigename
  host       String  // VERSCHLÜSSELT
  port       String  @default("22") // VERSCHLÜSSELT (String weil verschlüsselt)
  username   String  // VERSCHLÜSSELT
  authType   String  @default("password") // "password" | "key" — NICHT verschlüsselt
  password   String  @default("") // VERSCHLÜSSELT
  privateKey String  @default("") @db.Text // VERSCHLÜSSELT
  passphrase String  @default("") // VERSCHLÜSSELT
  notes      String  @default("") // VERSCHLÜSSELT

  // SHA-256-Fingerprint des SSH-Host-Keys (Trust-on-first-use).
  // NICHT verschlüsselt — der Host-Key ist öffentlich, kein Geheimnis.
  hostKeyFingerprint String @default("")

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("servers")
}

// ============================================================
// SHARE — Sicheres Teilen von Geheimnissen per Link (Zero-Knowledge)
// ============================================================
// Der Browser des Absenders verschlüsselt clientseitig (Web Crypto,
// AES-256-GCM). Der Schlüssel wandert im URL-Fragment (#...) und
// erreicht den Server NIE. Der Server speichert nur den opaken Blob
// + Metadaten. hasPin steuert lediglich die PIN-Abfrage im View —
// die PIN selbst wird kryptografisch in den Schlüssel eingemischt
// und ist dem Server unbekannt.
//
// blob:      base64(salt):base64(iv):base64(ciphertext) — Server blind
// token:     URL-sicherer Zufalls-Token für Lookup (nicht die id)
// maxViews:  0 = unbegrenzt bis Zeitablauf, sonst burn-after-N-views
// expiresAt: NICHT verschlüsselt (für Cleanup/Query)
// ============================================================
model Share {
  id        String   @id @default(uuid())
  token     String   @unique
  blob      String   @db.Text
  hasPin    Boolean  @default(false)
  maxViews  Int      @default(1)
  viewCount Int      @default(0)
  expiresAt DateTime

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("shares")
}
