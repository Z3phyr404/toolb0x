// ============================================================
// DATENBANK-SCHEMA — mit Verschlüsselung
// ============================================================
// Sensible Felder (name, amount) werden als String gespeichert,
// weil der verschlüsselte Text ein Base64-String ist.
// In der DB sieht man nur Kauderwelsch.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("user")  // "user" | "admin"
  suspended    Boolean  @default(false)   // Gesperrte Nutzer können sich nicht einloggen
  encryptedKey String   // Encryption Key, verschlüsselt mit dem User-Passwort

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories  Category[]
  expenses    Expense[]
  incomes     Income[]
  monthInits  MonthInit[]
  reminders   Reminder[]

  @@map("users")
}

model Category {
  id    String @id @default(uuid())
  name  String   // VERSCHLÜSSELT
  color String   // VERSCHLÜSSELT

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("categories")
}

model Expense {
  id     String @id @default(uuid())
  name   String   // VERSCHLÜSSELT
  amount String   // VERSCHLÜSSELT (String weil Base64)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  tags       String   @default("")   // VERSCHLÜSSELT (JSON-Array als String, z.B. '["Wocheneinkauf","Online"]')

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       String  @default("2026-02")  // NICHT verschlüsselt (für DB-Queries)
  isRecurring Boolean @default(true)

  reminders Reminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@map("expenses")
}

model Income {
  id     String @id @default(uuid())
  name   String   // VERSCHLÜSSELT
  amount String   // VERSCHLÜSSELT

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       String  @default("2026-02")
  isRecurring Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@map("incomes")
}

// Trackt ob ein Monat bereits für einen User initialisiert wurde.
// Verhindert dass gelöschte Einträge nach einem Refresh wieder auftauchen.
model MonthInit {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  month  String  // Format: "YYYY-MM"
  type   String  // "expense" | "income"

  createdAt DateTime @default(now())

  @@unique([userId, month, type])
  @@index([userId, month])
  @@map("month_inits")
}

// ============================================================
// ERINNERUNGEN — Kündigungserinnerungen für Ausgaben
// ============================================================
// reminderDate und daysBefore sind NICHT verschlüsselt (für DB-Queries).
// note ist verschlüsselt (Zero-Knowledge).
// expenseId ist optional — Erinnerung überlebt gelöschte Ausgabe (SetNull).
// ============================================================
model Reminder {
  id           String   @id @default(uuid())
  note         String   @default("")   // VERSCHLÜSSELT (optionale Notiz)
  reminderDate DateTime                // NICHT verschlüsselt (für DB-Queries)
  daysBefore   Int      @default(3)    // Tage vorher erinnern (0–90)
  status       String   @default("pending") // "pending" | "done" | "dismissed"

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, reminderDate])
  @@map("reminders")
}
