// ============================================================
// DATENBANK-SCHEMA — mit Verschlüsselung
// ============================================================
// Sensible Felder (name, amount) werden als String gespeichert,
// weil der verschlüsselte Text ein Base64-String ist.
// In der DB sieht man nur Kauderwelsch.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  encryptedKey String   // Encryption Key, verschlüsselt mit dem User-Passwort

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
  expenses   Expense[]
  incomes    Income[]

  @@map("users")
}

model Category {
  id    String @id @default(uuid())
  name  String   // VERSCHLÜSSELT
  color String   // VERSCHLÜSSELT

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("categories")
}

model Expense {
  id     String @id @default(uuid())
  name   String   // VERSCHLÜSSELT
  amount String   // VERSCHLÜSSELT (String weil Base64)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       String  @default("2026-02")  // NICHT verschlüsselt (für DB-Queries)
  isRecurring Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@map("expenses")
}

model Income {
  id     String @id @default(uuid())
  name   String   // VERSCHLÜSSELT
  amount String   // VERSCHLÜSSELT

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  month       String  @default("2026-02")
  isRecurring Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, month])
  @@map("incomes")
}
